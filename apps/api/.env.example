# API (Railway/Render/local)
NODE_ENV=development
PORT=3001

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

GEMINI_API_KEY=
GEMINI_MODEL_QUESTIONS=gemini-2.5-flash
GEMINI_MODEL_EVAL=gemini-2.5-flash
GEMINI_MODEL_REPORT=gemini-2.5-flash

# Comma-separated list of allowed origins for CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Storage buckets (must exist in Supabase before first use)
AUDIO_BUCKET=audio
AUDIO_RETENTION_DAYS=30
# NOTE: 'resumes' bucket is also required (created via migration 0003_storage_buckets.sql)

# Optional: protect /internal/cron/audio-cleanup endpoint
CRON_SECRET=

RATE_LIMIT_MAX=120
RATE_LIMIT_TIME_WINDOW_MS=60000
